# Server
PORT=5000
NODE_ENV=development

# Database
# Local (Docker):
MONGODB_URI=mongodb://mongo:27017/solarspot_dev
# Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/solarspot?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_with_32_char_random_secret
JWT_REFRESH_SECRET=replace_with_different_32_char_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# OpenWeatherMap
OPENWEATHERMAP_API_KEY=your_owm_api_key_here

# Google Perspective API
PERSPECTIVE_API_KEY=your_perspective_api_key_here

# Brevo SMTP
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your_brevo_account_email
BREVO_SMTP_PASS=your_brevo_smtp_key_here
EMAIL_FROM=noreply@solarspot.app

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS
FRONTEND_URL=http://localhost:3000
