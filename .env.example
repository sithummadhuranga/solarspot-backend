# ─────────────────────────────────────────────────────────────────────────────
# SolarSpot Backend — Environment Variables
#
# HOW TO USE:
#   cp .env.example .env
#   Fill in every REQUIRED value before starting the app.
#   .env is listed in .gitignore — never commit it.
#
# GENERATE SECRETS (run once in terminal):
#   JWT_SECRET  : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#   COOKIE_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
APP_NAME=SolarSpot
APP_URL=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
# REQUIRED — Atlas SRV: Dashboard → Database → Connect → Drivers → copy SRV URI
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=solarspot

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# REQUIRED — min 64 chars random hex
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# REQUIRED — min 32 chars random hex
COOKIE_SECRET=REPLACE_WITH_32_CHAR_RANDOM_HEX

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Email — Brevo SMTP (free: 300 emails/day) ─────────────────────────────────
# Sign up: https://www.brevo.com → SMTP & API → Generate SMTP key
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-brevo-login@email.com   # REQUIRED — your Brevo account email
EMAIL_PASS=your-brevo-smtp-api-key      # REQUIRED — not your Brevo account password
EMAIL_FROM_NAME=SolarSpot
EMAIL_FROM_ADDRESS=no-reply@solarspot.app
EMAIL_PREVIEW=true     # DEV: logs email to console, never actually sends

# ── OpenWeatherMap (free: 1,000 calls/day) ────────────────────────────────────
# https://openweathermap.org/api → One Call API 3.0
OPENWEATHER_API_KEY=REPLACE_WITH_YOUR_KEY

# ── Perspective API — content moderation (free, Google account required) ──────
# https://perspectiveapi.com → Google Cloud Console → API key
PERSPECTIVE_API_KEY=REPLACE_WITH_YOUR_KEY

# ── Cloudinary — image CDN (free: 25 GB) ─────────────────────────────────────
# https://cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=REPLACE_WITH_YOUR_CLOUD_NAME
CLOUDINARY_API_KEY=REPLACE_WITH_YOUR_API_KEY
CLOUDINARY_API_SECRET=REPLACE_WITH_YOUR_API_SECRET
