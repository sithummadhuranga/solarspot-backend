{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "../..",
    "paths": {
      "@/*":           ["src/*"],
      "@config/*":     ["src/config/*"],
      "@middleware/*": ["src/middleware/*"],
      "@modules/*":   ["src/modules/*"],
      "@services/*":  ["src/services/*"],
      "@utils/*":     ["src/utils/*"]
    },
    "types": ["jest", "node"],
    "noImplicitReturns": false
  },
  "exclude": ["../../node_modules", "../../dist"],
  "include": [
    "./**/*.ts"
  ],
  "exclude": [
    "../../node_modules",
    "../../dist"
  ]
}
