{
  "name": "solarspot-backend",
  "version": "1.0.0",
  "description": "SolarSpot REST API — SE3040 Assignment 2026",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "dev": "nodemon",
    "seed": "ts-node -r tsconfig-paths/register src/seed/index.ts",
    "seed:core": "ts-node -r tsconfig-paths/register src/seed/index.ts --core",
    "seed:demo": "ts-node -r tsconfig-paths/register src/seed/index.ts --demo",
    "seed:reset": "ts-node -r tsconfig-paths/register src/seed/index.ts --reset",
    "seed:verify": "ts-node -r tsconfig-paths/register src/seed/verify.ts",
    "test": "jest --config jest.config.ts --runInBand --forceExit",
    "test:unit": "jest --config jest.config.ts --testPathPattern=tests/unit --coverage --forceExit",
    "test:integration": "jest --config jest.integration.config.ts --runInBand --forceExit",
    "test:coverage": "jest --config jest.config.ts --coverage --runInBand --forceExit",
    "lint": "eslint src app.ts server.ts",
    "format": "prettier --write \"src/**/*.ts\" app.ts server.ts"
  },
  "dependencies": {
    "@types/cookie-parser": "^1.4.10",
    "axios": "^1.6.2",
    "bcryptjs": "^3.0.2",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^5.0.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.0.0",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.0.0",
    "morgan": "^1.10.0",
    "node-cache": "^5.1.2",
    "nodemailer": "^7.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/hpp": "^0.2.5",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.14",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.0.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.2",
    "typescript-eslint": "^8.0.0"
  }
}
